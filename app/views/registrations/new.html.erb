<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">CrewBoard</h1>
    <p class="auth-subtitle">Create your account</p>

    <% if @account.errors.any? || @manager.errors.any? %>
      <div class="alert alert-danger">
        <% (@account.errors.full_messages + @manager.errors.full_messages).uniq.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <%= form_with url: registration_path, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :account_name, "Company Name" %>
        <%= f.text_field :account_name, name: "account[name]", value: @account.name, required: true, placeholder: "Your company name", autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :email_address, "Email" %>
        <%= f.email_field :email_address, name: "manager[email_address]", value: @manager.email_address, required: true, placeholder: "you@company.com" %>
      </div>

      <div class="form-group" data-controller="password-visibility">
        <%= f.label :password, "Password" %>
        <div class="input-with-icon">
          <%= f.password_field :password, name: "manager[password]", required: true, placeholder: "Min 6 characters", data: { password_visibility_target: "input" } %>
          <button type="button" class="input-icon-btn" data-action="click->password-visibility#toggle" aria-label="Toggle password visibility">
            <svg data-password-visibility-target="showIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg data-password-visibility-target="hideIcon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </div>

      <div class="form-group" data-controller="password-visibility">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <div class="input-with-icon">
          <%= f.password_field :password_confirmation, name: "manager[password_confirmation]", required: true, placeholder: "Confirm password", data: { password_visibility_target: "input" } %>
          <button type="button" class="input-icon-btn" data-action="click->password-visibility#toggle" aria-label="Toggle password visibility">
            <svg data-password-visibility-target="showIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg data-password-visibility-target="hideIcon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </div>

      <%= f.submit "Create Account", class: "btn btn-primary btn-full" %>
    <% end %>

    <p style="text-align: center; margin-top: 1rem; font-size: 0.875rem; color: var(--color-text-secondary);">
      Already have an account? <%= link_to "Sign in", new_session_path %>
    </p>
  </div>
</div>
