<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">CrewBoard</h1>
    <p class="auth-subtitle">Create your account</p>

    <% if @account.errors.any? || @manager.errors.any? %>
      <div class="alert alert-danger">
        <% (@account.errors.full_messages + @manager.errors.full_messages).uniq.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <%= form_with url: registration_path, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :account_name, "Company Name" %>
        <%= f.text_field :account_name, name: "account[name]", value: @account.name, required: true, placeholder: "Your company name", autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :email_address, "Email" %>
        <%= f.email_field :email_address, name: "manager[email_address]", value: @manager.email_address, required: true, placeholder: "you@company.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Password" %>
        <%= f.password_field :password, name: "manager[password]", required: true, placeholder: "Min 6 characters" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation, name: "manager[password_confirmation]", required: true, placeholder: "Confirm password" %>
      </div>

      <%= f.submit "Create Account", class: "btn btn-primary btn-full" %>
    <% end %>

    <p style="text-align: center; margin-top: 1rem; font-size: 0.875rem; color: var(--color-text-secondary);">
      Already have an account? <%= link_to "Sign in", new_session_path %>
    </p>
  </div>
</div>
