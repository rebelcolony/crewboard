<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">CrewControl</h1>
    <p class="auth-subtitle">Set a new password</p>

    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <% if flash[:notice] %>
      <div class="alert alert-success"><%= flash[:notice] %></div>
    <% end %>

    <%= form_with model: @manager, url: password_reset_path(token: params[:token]), method: :patch, class: "auth-form" do |f| %>
      <% if @manager.errors.any? %>
        <div class="alert alert-danger">
          <% @manager.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-group" data-controller="password-visibility">
        <%= f.label :password, "New Password" %>
        <div class="password-field-wrapper">
          <%= f.password_field :password, autofocus: true, required: true, placeholder: "Min 8 characters", data: { password_visibility_target: "input" } %>
          <button type="button" class="password-visibility-toggle" data-action="click->password-visibility#toggle" aria-label="Toggle password visibility">
            <svg data-password-visibility-target="showIcon" class="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <svg data-password-visibility-target="hideIcon" class="eye-icon hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
              <line x1="1" y1="1" x2="23" y2="23"></line>
            </svg>
          </button>
        </div>
      </div>

      <div class="form-group" data-controller="password-visibility">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <div class="password-field-wrapper">
          <%= f.password_field :password_confirmation, required: true, placeholder: "Confirm new password", data: { password_visibility_target: "input" } %>
          <button type="button" class="password-visibility-toggle" data-action="click->password-visibility#toggle" aria-label="Toggle password visibility">
            <svg data-password-visibility-target="showIcon" class="eye-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <svg data-password-visibility-target="hideIcon" class="eye-icon hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path>
              <line x1="1" y1="1" x2="23" y2="23"></line>
            </svg>
          </button>
        </div>
      </div>

      <%= f.submit "Reset Password", class: "btn btn-primary btn-full" %>
    <% end %>

    <p style="text-align: center; margin-top: 1rem; font-size: 0.875rem; color: var(--color-text-secondary);">
      Remember your password? <%= link_to "Sign in", new_session_path %>
    </p>
  </div>
</div>
