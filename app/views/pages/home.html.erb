<% content_for(:page_title) { "CrewControl — Team Coordination & Project Management Software" } %>
<% content_for(:page_description) { "Real-time team allocation, project oversight, and crew management. CrewControl gives managers complete visibility over people, projects, and assignments." } %>

<!-- Schema.org SoftwareApplication -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "CrewControl",
  "description": "Team coordination and crew management software. Get real-time visibility over people, projects, and assignments. Visual operations dashboard, drag & drop allocation, multi-project control.",
  "url": "<%= root_url %>",
  "applicationCategory": "BusinessApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "description": "Free plan with 1 project and up to 10 team members"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "24"
  },
  "operatingSystem": "Web",
  "screenshot": "<%= "#{request.base_url}/og-image.png" %>"
}
</script>

<%# ── Hero ── %>
<section class="hero">
  <div class="marketing-container">
    <span class="hero-eyebrow">Team coordination software</span>

    <h1 class="hero-headline">
      Every team. Every project.<br>
      One clear view.
    </h1>

    <p class="hero-subheadline">
      CrewControl gives managers complete visibility over people, projects, and assignments
      in real time — so you always know who’s working on what, where, and what needs attention next.
    </p>

    <div class="hero-actions">
      <%= link_to "Get Started Free", new_registration_path, class: "btn btn-primary btn-lg" %>
      <%= link_to "See Features", "#features", class: "btn btn-ghost btn-lg" %>
    </div>

    <div class="hero-proof">
      <span class="badge badge-accent">Live team allocation</span>
      <span class="badge badge-success">Real-time visibility</span>
      <span class="badge badge-secondary">Multi-project oversight</span>
    </div>
  </div>
</section>

<%# ── Problem / Before Section ── %>
<section class="story-section story-section-chaos">
  <div class="marketing-container">
    <div class="story-grid">
      <div class="story-copy">
        <span class="section-kicker">The problem</span>
        <h2 class="section-title section-title-left">
          Managing multiple teams shouldn’t feel like this
        </h2>
        <p class="section-subtitle section-subtitle-left">
          When team allocation lives across whiteboards, sticky notes, phone calls, spreadsheets,
          and memory, project coordination becomes reactive, fragile, and hard to scale.
        </p>

        <div class="story-points">
          <div class="story-point">
            <strong>No single source of truth</strong>
            <p>Assignments change fast, but updates don’t always reach everyone who needs them.</p>
          </div>

          <div class="story-point">
            <strong>Too much manual coordination</strong>
            <p>Managers waste time chasing who’s available, who moved, and what project is now at risk.</p>
          </div>

          <div class="story-point">
            <strong>Visibility breaks as you grow</strong>
            <p>What works for two teams quickly breaks down when you’re coordinating five, ten, or more.</p>
          </div>
        </div>
      </div>

      <div class="story-visual">
        <div class="story-image-frame">
          <%= image_tag "chaos-whiteboard.png",
              alt: "Project manager facing a messy whiteboard while trying to coordinate multiple teams and projects",
              class: "story-image" %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ── Solution Section ── %>
<section class="story-section story-section-solution">
  <div class="marketing-container">
    <div class="story-grid story-grid-reverse">
      <div class="story-visual">
        <div class="solution-preview card">
          <div class="solution-preview-header">
            <div>
              <div class="solution-preview-title">Operations Dashboard</div>
              <div class="solution-preview-subtitle">Live team allocation across projects</div>
            </div>
            <span class="badge badge-success">Live</span>
          </div>

          <div class="solution-project-list">
            <div class="solution-project">
              <div class="solution-project-top">
                <strong>Project Atlas</strong>
                <span class="badge badge-accent">On Track</span>
              </div>
              <div class="progress-bar">
                <div class="progress-bar-fill progress-bar-success" style="width: 72%;"></div>
              </div>
              <div class="solution-avatars">
                <span class="avatar avatar-sm"><span class="avatar-initials">AB</span></span>
                <span class="avatar avatar-sm"><span class="avatar-initials">JT</span></span>
                <span class="avatar avatar-sm"><span class="avatar-initials">MS</span></span>
              </div>
            </div>

            <div class="solution-project">
              <div class="solution-project-top">
                <strong>North Terminal</strong>
                <span class="badge badge-warning">Attention</span>
              </div>
              <div class="progress-bar">
                <div class="progress-bar-fill progress-bar-warning" style="width: 41%;"></div>
              </div>
              <div class="solution-avatars">
                <span class="avatar avatar-sm"><span class="avatar-initials">RK</span></span>
                <span class="avatar avatar-sm"><span class="avatar-initials">PL</span></span>
              </div>
            </div>

            <div class="solution-project">
              <div class="solution-project-top">
                <strong>Field Services East</strong>
                <span class="badge badge-secondary">Planning</span>
              </div>
              <div class="progress-bar">
                <div class="progress-bar-fill progress-bar-accent" style="width: 58%;"></div>
              </div>
              <div class="solution-avatars">
                <span class="avatar avatar-sm"><span class="avatar-initials">DM</span></span>
                <span class="avatar avatar-sm"><span class="avatar-initials">SC</span></span>
                <span class="avatar avatar-sm"><span class="avatar-initials">JB</span></span>
                <span class="avatar avatar-sm"><span class="avatar-initials">EL</span></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="story-copy">
        <span class="section-kicker">The solution</span>
        <h2 class="section-title section-title-left">
          Replace operational chaos with visual control
        </h2>
        <p class="section-subtitle section-subtitle-left">
          CrewControl gives you a live dashboard for team allocation, project oversight,
          and assignment changes — all in one place.
        </p>

        <div class="story-points">
          <div class="story-point">
            <strong>See everything at a glance</strong>
            <p>Projects, teams, progress, and status all appear in one clean operational view.</p>
          </div>

          <div class="story-point">
            <strong>Reassign people in seconds</strong>
            <p>Drag and drop team members between projects without the admin mess.</p>
          </div>

          <div class="story-point">
            <strong>Make faster decisions</strong>
            <p>Spot bottlenecks, gaps, and overloaded teams before they become delays.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ── Features ── %>
<section class="features" id="features">
  <div class="marketing-container">
    <h2 class="section-title">Built for teams that manage people, not just tasks</h2>
    <p class="section-subtitle">
      Whether you coordinate field crews, engineering teams, inspection staff,
      operations personnel, or service teams — CrewControl gives you one place to run the picture.
    </p>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        </div>
        <h3>Visual Operations Dashboard</h3>
        <p>See every project, team, and assignment in one place. Clear visual cards replace messy spreadsheets and fragmented tools.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3>Drag &amp; Drop Team Allocation</h3>
        <p>Move people between projects in seconds. Adapt quickly when priorities shift, jobs change, or resources tighten.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>Real-Time Visibility</h3>
        <p>Track project progress, team allocation, and status changes as they happen so nothing important gets missed.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3>Multi-Project Control</h3>
        <p>Coordinate multiple jobs, locations, and teams without losing oversight as your operation grows.</p>
      </div>
    </div>
  </div>
</section>

<%# ── Use Cases ── %>
<section class="use-cases-section">
  <div class="marketing-container">
    <h2 class="section-title">Works anywhere team coordination matters</h2>
    <p class="section-subtitle">
      Designed for real-world operations where people need to be assigned, moved, tracked, and managed clearly.
    </p>

    <div class="use-cases-grid">
      <div class="use-case-card">Inspection teams</div>
      <div class="use-case-card">Engineering crews</div>
      <div class="use-case-card">Field service crews</div>
      <div class="use-case-card">Maintenance operations</div>
      <div class="use-case-card">Construction teams</div>
      <div class="use-case-card">Trades management</div>
      <div class="use-case-card">Logistics &amp; support teams</div>
      <div class="use-case-card">Medical crews</div>
    </div>
  </div>
</section>

<%# ── Pricing ── %>
<section class="pricing-section" id="pricing" data-controller="currency-selector">
  <div class="marketing-container">
    <div class="pricing-header">
      <div>
        <h2 class="section-title">Simple, scalable pricing</h2>
        <p class="section-subtitle">Start small, then expand as your team grows.</p>
      </div>
      <div class="currency-selector">
        <label for="currency-select" class="currency-label">Currency:</label>
        <select id="currency-select" data-action="change->currency-selector#change" data-currency-selector-target="select" class="currency-select">
          <option value="usd">USD ($)</option>
          <option value="gbp">GBP (£)</option>
          <option value="eur">EUR (€)</option>
        </select>
      </div>
    </div>

    <div class="pricing-grid" data-currency-selector-target="grid">
      <div class="card pricing-card" data-usd="0" data-gbp="0" data-eur="0">
        <div class="pricing-card-header">
          <h3>Free</h3>
          <div class="pricing-price" data-currency-selector-target="price">$0<span class="pricing-period">/mo</span></div>
        </div>
        <ul class="pricing-features">
          <li>1 manager seat</li>
          <li>Up to 2 projects</li>
          <li>Up to 20 team members</li>
          <li>Community support</li>
        </ul>
        <%= link_to "Get Started", new_registration_path, class: "btn btn-ghost btn-full" %>
      </div>

      <div class="card pricing-card" data-usd="49" data-gbp="39" data-eur="46">
        <div class="pricing-card-header">
          <h3>Starter</h3>
          <div class="pricing-price" data-currency-selector-target="price">$49<span class="pricing-period">/mo</span></div>
        </div>
        <ul class="pricing-features">
          <li>1 manager seat</li>
          <li>Up to 5 projects</li>
          <li>50 team members</li>
          <li>Email support</li>
        </ul>
        <%= link_to "Get Started", new_registration_path, class: "btn btn-ghost btn-full" %>
      </div>

      <div class="card pricing-card pricing-card-featured" data-usd="149" data-gbp="119" data-eur="141">
        <div class="pricing-badge">Most Popular</div>
        <div class="pricing-card-header">
          <h3>Pro</h3>
          <div class="pricing-price" data-currency-selector-target="price">$149<span class="pricing-period">/mo</span></div>
        </div>
        <ul class="pricing-features">
          <li>5 manager seats</li>
          <li>Up to 20 projects</li>
          <li>Unlimited team members</li>
          <li>Priority support</li>
        </ul>
        <%= link_to "Get Started", new_registration_path, class: "btn btn-primary btn-full" %>
      </div>

      <div class="card pricing-card" data-usd="custom" data-gbp="custom" data-eur="custom">
        <div class="pricing-card-header">
          <h3>Enterprise</h3>
          <div class="pricing-price" data-currency-selector-target="price">Custom</div>
        </div>
        <ul class="pricing-features">
          <li>Unlimited seats</li>
          <li>SSO &amp; audit log</li>
          <li>API access</li>
          <li>Dedicated support</li>
        </ul>
        <%= link_to "Contact Sales", "mailto:support@crew-control.io", class: "btn btn-ghost btn-full" %>
      </div>
    </div>
  </div>
</section>

<%# ── CTA ── %>
<section class="cta-section">
  <div class="marketing-container" style="text-align: center;">
    <h2 class="section-title">Ready to bring order to your team operations?</h2>
    <p class="section-subtitle">
      Set up your dashboard in minutes and start managing projects with clarity.
      No credit card required.
    </p>
    <%= link_to "Create Your Free Account", new_registration_path, class: "btn btn-primary btn-lg" %>
  </div>
</section>