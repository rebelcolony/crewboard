<%= form_with model: project, class: "form", data: { turbo: false } do |f| %>
  <% if project.errors.any? %>
    <div class="alert alert-danger">
      <% project.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, required: true, placeholder: "e.g. Hull Inspection – Vessel Aurora" %>
  </div>

  <div class="form-group">
    <%= f.label :location %>
    <%= f.text_field :location, placeholder: "e.g. North Sea Platform Alpha" %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, rows: 3, placeholder: "Scope of work, key objectives, special requirements..." %>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :status %>
      <%= f.select :status, Project.statuses.keys.map { |s| [s.humanize, s] }, { include_blank: "Select status" } %>
    </div>

    <div class="form-group">
      <%= f.label :progress, "Progress (%)" %>
      <%= f.number_field :progress, min: 0, max: 100, step: 5 %>
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :start_date %>
      <%= f.date_field :start_date %>
    </div>

    <div class="form-group">
      <%= f.label :target_end_date %>
      <%= f.date_field :target_end_date %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", projects_path, class: "btn btn-secondary" %>
  </div>
<% end %>
