<%= turbo_frame_tag "modal" do %>
  <div class="modal-overlay" data-controller="modal" data-action="click->modal#closeBackground keydown.escape@window->modal#close">
    <div class="modal-content" data-modal-target="content">
      <button class="modal-close" data-action="click->modal#close">&times;</button>

      <h2><%= @project.name %></h2>
      <p class="text-secondary"><%= @project.location %></p>

      <div class="modal-details">
        <div class="detail-row">
          <span class="detail-label">Status</span>
          <span class="badge badge-<%= @project.status_color %>"><%= @project.status.humanize %></span>
        </div>

        <div class="detail-row">
          <span class="detail-label">Progress</span>
          <div class="progress-bar">
            <div class="progress-bar-fill" style="width: <%= @project.progress %>%"></div>
          </div>
          <span><%= @project.progress %>%</span>
        </div>

        <% if @project.start_date || @project.target_end_date %>
          <div class="detail-row">
            <span class="detail-label">Dates</span>
            <span>
              <%= @project.start_date&.strftime("%b %d, %Y") || "TBD" %>
              &mdash;
              <%= @project.target_end_date&.strftime("%b %d, %Y") || "TBD" %>
            </span>
          </div>
        <% end %>

        <% if @project.description.present? %>
          <div class="detail-section">
            <span class="detail-label">Description</span>
            <p><%= @project.description %></p>
          </div>
        <% end %>

        <div class="detail-section">
          <span class="detail-label">Crew (<%= @project.crew_members.size %>)</span>
          <div class="crew-list">
            <% @project.crew_members.each do |member| %>
              <div class="crew-list-item">
                <div class="avatar avatar-sm">
                  <img src="<%= member.avatar_url(size: 64) %>"
                       alt="<%= member.name %>"
                       class="avatar-img"
                       loading="lazy"
                       onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                  <span class="avatar-initials" style="display: none;"><%= member.initials %></span>
                </div>
                <div>
                  <strong><%= member.name %></strong>
                  <span class="text-secondary"><%= member.role %></span>
                </div>
              </div>
            <% end %>
            <% if @project.crew_members.empty? %>
              <p class="text-secondary">No crew assigned</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="modal-actions">
        <%= link_to "Edit Project", edit_project_path(@project), class: "btn btn-secondary", data: { turbo_frame: "_top" } %>
      </div>
    </div>
  </div>
<% end %>
