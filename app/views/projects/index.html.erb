<div class="page-header">
  <h1>Projects</h1>
  <%= link_to "New Project", new_project_path, class: "btn btn-primary" %>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Location</th>
      <th>Status</th>
      <th>Progress</th>
      <th>Crew</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @projects.each do |project| %>
      <tr>
        <td data-label="Name"><%= project.name %></td>
        <td data-label="Location"><%= project.location %></td>
        <td data-label="Status"><span class="badge badge-<%= project.status_color %>"><%= project.status.humanize %></span></td>
        <td data-label="Progress">
          <div class="progress-bar-sm">
            <div class="progress-bar-fill" style="width: <%= project.progress %>%"></div>
          </div>
          <span class="text-secondary text-sm"><%= project.progress %>%</span>
        </td>
        <td data-label="Crew"><%= project.crew_members.size %></td>
        <td data-label="Actions" class="table-actions">
          <%= link_to "Edit", edit_project_path(project), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", project_path(project), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Delete #{project.name}?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
