<div class="modal-overlay" data-controller="modal" data-action="click->modal#closeBackground keydown.escape@window->modal#close">
  <div class="modal-content" data-modal-target="content">
    <button class="modal-close" data-action="click->modal#close">&times;</button>

    <%= form_with model: project, class: "modal-edit-form", data: { controller: "inline-edit", action: "turbo:submit-end->inline-edit#onSubmitEnd" } do |f| %>
      <div class="inline-field inline-field-title">
        <%= f.text_field :name, class: "inline-input inline-input-title", placeholder: "Project name", data: { action: "input->inline-edit#save" } %>
      </div>

      <div class="inline-field">
        <%= f.text_field :location, class: "inline-input inline-input-subtitle", placeholder: "Location", data: { action: "input->inline-edit#save" } %>
      </div>

      <div class="modal-details">
        <div class="detail-row">
          <span class="detail-label">Status</span>
          <%= f.select :status, Project.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "inline-select", data: { action: "change->inline-edit#save" } %>
        </div>

        <div class="detail-row">
          <span class="detail-label">Progress</span>
          <div class="detail-control">
            <%= f.range_field :progress, min: 0, max: 100, step: 5, class: "inline-range", data: { action: "input->inline-edit#updateProgress input->inline-edit#save", "inline-edit-target": "range" } %>
            <span data-inline-edit-target="progressValue" class="inline-progress-value"><%= project.progress %>%</span>
          </div>
        </div>

        <div class="detail-row">
          <span class="detail-label">Start</span>
          <%= f.date_field :start_date, class: "inline-input inline-input-date", data: { action: "change->inline-edit#save" } %>
        </div>

        <div class="detail-row">
          <span class="detail-label">End</span>
          <%= f.date_field :target_end_date, class: "inline-input inline-input-date", data: { action: "change->inline-edit#save" } %>
        </div>

        <div class="detail-section">
          <span class="detail-label">Description</span>
          <%= f.text_area :description, class: "inline-textarea", rows: 3, placeholder: "Add a description...", data: { action: "input->inline-edit#save" } %>
        </div>

        <div class="detail-section">
          <span class="detail-label">Crew (<%= project.crew_members.size %>)</span>
          <div class="crew-list">
            <% project.crew_members.each do |member| %>
              <div class="crew-list-item">
                <div class="avatar avatar-sm avatar-color-<%= member.id % 6 %>">
                  <% if (url = member.avatar_url(size: 64)) %>
                    <img src="<%= url %>"
                         alt="<%= member.name %>"
                         class="avatar-img"
                         loading="lazy"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                  <% end %>
                  <span class="avatar-initials" style="<%= url ? 'display: none;' : '' %>"><%= member.initials %></span>
                </div>
                <div>
                  <strong><%= member.name %></strong>
                  <span class="text-secondary"><%= member.role %></span>
                </div>
              </div>
            <% end %>
            <% if project.crew_members.empty? %>
              <p class="text-secondary">No crew assigned</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="modal-actions">
        <span data-inline-edit-target="status" class="inline-save-status"></span>
      </div>
    <% end %>
  </div>
</div>
