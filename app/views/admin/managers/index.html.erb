<div class="page-header">
  <h1>Managers</h1>
  <%= link_to "New Manager", new_admin_manager_path, class: "btn btn-primary" %>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Email</th>
      <th>Account</th>
      <th>Super Admin</th>
      <th>Created</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @managers.each do |manager| %>
      <tr>
        <td><%= link_to manager.email_address, admin_manager_path(manager) %></td>
        <td><%= link_to manager.account.name, admin_account_path(manager.account) %></td>
        <td><%= manager.super_admin? ? "Yes" : "No" %></td>
        <td class="text-secondary text-sm"><%= manager.created_at.strftime("%b %d, %Y") %></td>
        <td class="table-actions">
          <%= link_to "Edit", edit_admin_manager_path(manager), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", admin_manager_path(manager), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Delete this manager?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
