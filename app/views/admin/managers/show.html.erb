<div class="page-header">
  <h1><%= @manager.email_address %></h1>
  <%= link_to "Edit", edit_admin_manager_path(@manager), class: "btn btn-secondary" %>
</div>

<div class="card">
  <div class="detail-row">
    <span class="detail-label">Account</span>
    <span><%= link_to @manager.account.name, admin_account_path(@manager.account) %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Super Admin</span>
    <span><%= @manager.super_admin? ? "Yes" : "No" %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Created</span>
    <span><%= @manager.created_at.strftime("%b %d, %Y at %H:%M") %></span>
  </div>
</div>
