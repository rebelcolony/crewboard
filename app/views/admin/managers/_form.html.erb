<div class="form">
  <%= form_with model: [:admin, manager] do |f| %>
    <% if manager.errors.any? %>
      <div class="alert alert-danger">
        <% manager.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :email_address, "Email" %>
      <%= f.email_field :email_address, required: true %>
    </div>

    <div class="form-group">
      <%= f.label :account_id, "Account" %>
      <%= f.collection_select :account_id, Account.order(:name), :id, :name, { prompt: "Select account" } %>
    </div>

    <div class="form-row">
      <div class="form-group">
        <%= f.label :password %>
        <%= f.password_field :password, placeholder: manager.persisted? ? "Leave blank to keep" : "" %>
      </div>
      <div class="form-group">
        <%= f.label :password_confirmation, "Confirm Password" %>
        <%= f.password_field :password_confirmation %>
      </div>
    </div>

    <div class="form-group">
      <%= f.check_box :super_admin %>
      <%= f.label :super_admin, "Super Admin" %>
    </div>

    <div class="form-actions">
      <%= f.submit class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_managers_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
