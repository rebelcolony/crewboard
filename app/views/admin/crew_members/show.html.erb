<div class="page-header">
  <h1><%= @crew_member.name %></h1>
  <%= link_to "Edit", edit_admin_crew_member_path(@crew_member), class: "btn btn-secondary" %>
</div>

<div class="card">
  <div class="detail-row">
    <span class="detail-label">Role</span>
    <span><%= @crew_member.role %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Account</span>
    <span><%= link_to @crew_member.account.name, admin_account_path(@crew_member.account) %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Project</span>
    <span><%= @crew_member.project ? link_to(@crew_member.project.name, admin_project_path(@crew_member.project)) : "Unassigned" %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Email</span>
    <span><%= @crew_member.email %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Phone</span>
    <span><%= @crew_member.phone.presence || "—" %></span>
  </div>
</div>
