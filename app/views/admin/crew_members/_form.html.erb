<div class="form">
  <%= form_with model: [:admin, crew_member] do |f| %>
    <% if crew_member.errors.any? %>
      <div class="alert alert-danger">
        <% crew_member.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :account_id, "Account" %>
      <%= f.collection_select :account_id, Account.order(:name), :id, :name, { prompt: "Select account" } %>
    </div>

    <div class="form-group">
      <%= f.label :name %>
      <%= f.text_field :name, required: true %>
    </div>

    <div class="form-group">
      <%= f.label :role %>
      <%= f.text_field :role %>
    </div>

    <div class="form-row">
      <div class="form-group">
        <%= f.label :email %>
        <%= f.email_field :email %>
      </div>
      <div class="form-group">
        <%= f.label :phone %>
        <%= f.text_field :phone %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_crew_members_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
