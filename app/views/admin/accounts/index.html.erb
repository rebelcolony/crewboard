<div class="page-header">
  <h1>Accounts</h1>
  <%= link_to "New Account", new_admin_account_path, class: "btn btn-primary" %>
</div>

<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Subdomain</th>
      <th>Plan</th>
      <th>Managers</th>
      <th>Projects</th>
      <th>Crew</th>
      <th>Created</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @accounts.each do |account| %>
      <tr>
        <td data-label="Name"><%= link_to account.name, admin_account_path(account) %></td>
        <td data-label="Subdomain" class="text-secondary"><%= account.subdomain.presence || "—" %></td>
        <td data-label="Plan"><span class="badge badge-accent"><%= account.plan_name.capitalize %></span></td>
        <td data-label="Managers"><%= account.managers.count %></td>
        <td data-label="Projects"><%= account.projects.count %></td>
        <td data-label="Crew"><%= account.crew_members.count %></td>
        <td data-label="Created" class="text-secondary text-sm"><%= account.created_at.strftime("%b %d, %Y") %></td>
        <td data-label="Actions" class="table-actions">
          <%= link_to "Edit", edit_admin_account_path(account), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", admin_account_path(account), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Delete this account?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
