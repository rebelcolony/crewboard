<h1>Admin Dashboard</h1>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-card-label">Accounts</div>
    <div class="stat-card-value"><%= @total_accounts %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Managers</div>
    <div class="stat-card-value"><%= @total_managers %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Projects</div>
    <div class="stat-card-value"><%= @total_projects %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Crew Members</div>
    <div class="stat-card-value"><%= @total_crew %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Active Subscriptions</div>
    <div class="stat-card-value"><%= @active_subscriptions %></div>
  </div>
</div>

<h2 style="margin-bottom: 1rem;">Recent Accounts</h2>
<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Plan</th>
      <th>Managers</th>
      <th>Projects</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @recent_accounts.each do |account| %>
      <tr>
        <td><%= link_to account.name, admin_account_path(account) %></td>
        <td><span class="badge badge-accent"><%= account.plan %></span></td>
        <td><%= account.managers.count %></td>
        <td><%= account.projects.count %></td>
        <td class="text-secondary text-sm"><%= account.created_at.strftime("%b %d, %Y") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
