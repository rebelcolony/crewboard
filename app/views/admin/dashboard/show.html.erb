<h1>Admin Dashboard</h1>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-card-label"><i class="fa-solid fa-building"></i> Accounts</div>
    <div class="stat-card-value"><%= @total_accounts %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label"><i class="fa-solid fa-receipt"></i> Active Subscriptions</div>
    <div class="stat-card-value"><%= @active_subscriptions %></div>
  </div>
</div>

<h2 style="margin-bottom: 1rem;">Recent Accounts</h2>
<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Plan</th>
      <th>Managers</th>
      <th>Projects</th>
      <th>Created</th>
    </tr>
  </thead>
  <tbody>
    <% @recent_accounts.each do |account| %>
      <tr>
        <td data-label="Name"><%= link_to account.name, admin_account_path(account) %></td>
        <td data-label="Plan"><span class="badge badge-accent"><%= account.plan_name.capitalize %></span></td>
        <td data-label="Managers"><%= account.managers.count %></td>
        <td data-label="Projects"><%= account.projects.count %></td>
        <td data-label="Created" class="text-secondary text-sm"><%= account.created_at.strftime("%b %d, %Y") %></td>
      </tr>
    <% end %>
  </tbody>
</table>
