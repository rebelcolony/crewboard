<div class="page-header">
  <h1><%= @project.name %></h1>
  <%= link_to "Edit", edit_admin_project_path(@project), class: "btn btn-secondary" %>
</div>

<div class="card">
  <div class="detail-row">
    <span class="detail-label">Account</span>
    <span><%= link_to @project.account.name, admin_account_path(@project.account) %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Location</span>
    <span><%= @project.location %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Status</span>
    <span class="badge badge-<%= @project.status_color %>"><%= @project.status.humanize %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">Progress</span>
    <span><%= @project.progress %>%</span>
  </div>
  <% if @project.description.present? %>
    <div class="detail-section">
      <span class="detail-label">Description</span>
      <p><%= @project.description %></p>
    </div>
  <% end %>
</div>
