<div class="form">
  <%= form_with model: [:admin, project] do |f| %>
    <% if project.errors.any? %>
      <div class="alert alert-danger">
        <% project.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="form-group">
      <%= f.label :account_id, "Account" %>
      <%= f.collection_select :account_id, Account.order(:name), :id, :name, { prompt: "Select account" } %>
    </div>

    <div class="form-group">
      <%= f.label :name %>
      <%= f.text_field :name, required: true %>
    </div>

    <div class="form-group">
      <%= f.label :location %>
      <%= f.text_field :location %>
    </div>

    <div class="form-group">
      <%= f.label :description %>
      <%= f.text_area :description, rows: 3 %>
    </div>

    <div class="form-row">
      <div class="form-group">
        <%= f.label :status %>
        <%= f.select :status, Project.statuses.keys.map { |s| [s.humanize, s] } %>
      </div>
      <div class="form-group">
        <%= f.label :progress %>
        <%= f.number_field :progress, min: 0, max: 100 %>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_projects_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
