<div class="page-header">
  <h1>Crew Members</h1>
  <%= link_to "Add Crew Member", new_crew_member_path, class: "btn btn-primary" %>
</div>

<table class="table">
  <thead>
    <tr>
      <th></th>
      <th>Name</th>
      <th>Role</th>
      <th>Email</th>
      <th>Project</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @crew_members.each do |member| %>
      <tr>
        <td data-label="Avatar">
          <div class="avatar avatar-sm">
            <img src="<%= member.avatar_url(size: 64) %>"
                 alt="<%= member.name %>"
                 class="avatar-img"
                 loading="lazy"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
            <span class="avatar-initials" style="display: none;"><%= member.initials %></span>
          </div>
        </td>
        <td data-label="Name"><%= member.name %></td>
        <td data-label="Role"><%= member.role %></td>
        <td data-label="Email"><%= member.email %></td>
        <td data-label="Project"><%= member.project&.name || "Unassigned" %></td>
        <td data-label="Actions" class="table-actions">
          <%= link_to "Edit", edit_crew_member_path(member), class: "btn btn-sm btn-secondary" %>
          <%= button_to "Delete", crew_member_path(member), method: :delete, class: "btn btn-sm btn-danger", data: { turbo_confirm: "Remove #{member.name}?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
