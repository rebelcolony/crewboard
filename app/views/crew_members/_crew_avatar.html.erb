<div class="avatar avatar-color-<%= member.id % 6 %>"
     draggable="true"
     data-controller="draggable"
     data-draggable-crew-member-id-value="<%= member.id %>"
     data-action="dragstart->draggable#start dragend->draggable#end"
     title="<%= member.name %> — <%= member.role %>">
  <% if (url = member.avatar_url(size: 80)) %>
    <img src="<%= url %>"
         alt="<%= member.name %>"
         class="avatar-img"
         loading="lazy"
         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
  <% end %>
  <span class="avatar-initials" style="<%= url ? 'display: none;' : '' %>"><%= member.initials %></span>
</div>
