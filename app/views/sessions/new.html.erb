<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">CrewControl</h1>
    <p class="auth-subtitle">Project Management Dashboard</p>

    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with url: session_path, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :email_address, "Email" %>
        <%= f.email_field :email_address, autofocus: true, required: true, placeholder: "manager@example.com" %>
      </div>

      <div class="form-group">
        <%= f.label :password %>
        <%= f.password_field :password, required: true, placeholder: "Password" %>
      </div>

      <%= f.submit "Sign In", class: "btn btn-primary btn-full" %>
    <% end %>

    <p style="text-align: center; margin-top: 0.75rem; font-size: 0.875rem;">
      <%= link_to "Forgot your password?", new_password_reset_path %>
    </p>

    <p style="text-align: center; margin-top: 0.5rem; font-size: 0.875rem; color: var(--color-text-secondary);">
      Don't have an account? <%= link_to "Sign up", new_registration_path %>
    </p>
  </div>
</div>
