<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= content_for(:page_title) || "CrewControl - Sign In" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="<%= content_for(:page_description) || "Sign in to your CrewControl account." %>">
  
  <!-- Open Graph Tags -->
  <meta property="og:title" content="<%= content_for(:og_title) || content_for(:page_title) || "CrewControl - Sign In" %>">
  <meta property="og:description" content="<%= content_for(:og_description) || content_for(:page_description) || "Sign in to your CrewControl account." %>">
  <meta property="og:url" content="<%= content_for(:og_url) || request.url %>">
  <meta property="og:type" content="<%= content_for(:og_type) || "website" %>">
  <meta property="og:image" content="<%= content_for(:og_image) || "#{request.base_url}/og-image.png" %>">
  <meta property="og:image:alt" content="CrewControl">
  <meta property="og:site_name" content="CrewControl">
  
  <!-- Twitter Card Tags -->
  <meta name="twitter:card" content="<%= content_for(:twitter_card) || "summary_large_image" %>">
  <meta name="twitter:title" content="<%= content_for(:twitter_title) || content_for(:page_title) || "CrewControl - Sign In" %>">
  <meta name="twitter:description" content="<%= content_for(:twitter_description) || content_for(:page_description) || "Sign in to your CrewControl account." %>">
  <meta name="twitter:image" content="<%= content_for(:twitter_image) || "#{request.base_url}/og-image.png" %>">
  
  <!-- Schema.org Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "CrewControl",
    "url": "<%= root_url %>",
    "logo": "<%= "#{request.base_url}/icon.png" %>",
    "sameAs": [],
    "description": "Team coordination and crew management software for project ops. CrewControl gives managers complete visibility over people, projects, and assignments.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "GB",
      "addressLocality": "Tain",
      "postalCode": "IV19 1BJ",
      "streetAddress": "10 Knockbreak St"
    },
    "contact": {
      "@type": "ContactPoint",
      "contactType": "Customer Support",
      "email": "support@crew-control.io"
    }
  }
  </script>
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application" %>
  <%= javascript_importmap_tags %>
</head>
<body class="auth-body">
  <div style="display: flex; flex-direction: column; align-items: center; width: 100%;">
    <% if flash[:notice] %>
      <div class="auth-container" style="margin-bottom: 0;">
        <div class="alert alert-success" style="text-align: center;"><%= flash[:notice] %></div>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="auth-container" style="margin-bottom: 0;">
        <div class="alert alert-danger" style="text-align: center;"><%= flash[:alert] %></div>
      </div>
    <% end %>

    <%= yield %>
  </div>
</body>
</html>
