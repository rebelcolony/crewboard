<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= content_for(:page_title) || "CrewControl — Team Coordination & Project Management Software" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="<%= content_for(:page_description) || "Real-time team allocation, project oversight, and crew management. CrewControl gives managers complete visibility over people, projects, and assignments." %>">
  
  <!-- Open Graph Tags -->
  <meta property="og:title" content="<%= content_for(:og_title) || content_for(:page_title) || "CrewControl — Team Coordination & Project Management Software" %>">
  <meta property="og:description" content="<%= content_for(:og_description) || content_for(:page_description) || "Real-time team allocation, project oversight, and crew management. CrewControl gives managers complete visibility over people, projects, and assignments." %>">
  <meta property="og:url" content="<%= content_for(:og_url) || request.url %>">
  <meta property="og:type" content="<%= content_for(:og_type) || "website" %>">
  <meta property="og:image" content="<%= content_for(:og_image) || "#{request.base_url}/og-image.png" %>">
  <meta property="og:image:alt" content="CrewControl - Team Coordination Software">
  <meta property="og:site_name" content="CrewControl">
  
  <!-- Twitter Card Tags -->
  <meta name="twitter:card" content="<%= content_for(:twitter_card) || "summary_large_image" %>">
  <meta name="twitter:title" content="<%= content_for(:twitter_title) || content_for(:page_title) || "CrewControl — Team Coordination & Project Management Software" %>">
  <meta name="twitter:description" content="<%= content_for(:twitter_description) || content_for(:page_description) || "Real-time team allocation, project oversight, and crew management. CrewControl gives managers complete visibility over people, projects, and assignments." %>">
  <meta name="twitter:image" content="<%= content_for(:twitter_image) || "#{request.base_url}/og-image.png" %>">
  
  <!-- Schema.org Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "CrewControl",
    "url": "<%= root_url %>",
    "logo": "<%= "#{request.base_url}/icon.png" %>",
    "sameAs": [],
    "description": "Team coordination and crew management software for project ops. CrewControl gives managers complete visibility over people, projects, and assignments.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "GB",
      "addressLocality": "Tain",
      "postalCode": "IV19 1BJ",
      "streetAddress": "10 Knockbreak St"
    },
    "contact": {
      "@type": "ContactPoint",
      "contactType": "Customer Support",
      "email": "support@crew-control.io"
    }
  }
  </script>
  
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
  <script src="https://kit.fontawesome.com/ce3803b809.js" crossorigin="anonymous"></script>
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
  <link rel="icon" href="/icon-128.png" type="image/png" sizes="128x128">
  <link rel="icon" href="/icon-256.png" type="image/png" sizes="256x256">
  <link rel="apple-touch-icon" href="/icon.png" sizes="512x512">
  <%= stylesheet_link_tag "application" %>
  <%= javascript_importmap_tags %>
</head>
<body class="marketing-body">
  <nav class="marketing-nav" data-controller="mobile-nav" data-action="resize@window->mobile-nav#closeOnDesktop">
    <div class="marketing-nav-inner">
      <a href="<%= root_path %>" class="marketing-logo">CrewControl</a>
      <div class="marketing-nav-links">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="#demo">Watch Demo</a>
      </div>
      <div class="marketing-nav-actions">
        <%= link_to "Sign In", new_session_path, class: "btn btn-ghost" %>
        <%= link_to "Get Started", new_registration_path, class: "btn btn-primary btn-sm" %>
      </div>
    </div>
  </nav>

  <%= yield %>

  <footer class="marketing-footer">
    <div class="marketing-container">
      <div class="footer-links">
        <%= link_to "Privacy", privacy_path %>
        <%= link_to "Terms", terms_path %>
        <%= link_to "Cookies", cookies_path %>
        <a href="mailto:support@crew-control.io">Contact</a>
      </div>
      <p>&copy; <%= Date.current.year %> CrewControl. Built for offshore inspection teams.</p>
      <p class="footer-company">CrewControl is a service offered by Rebel Colony Ltd, a company registered in Scotland (SC570568). 10 Knockbreak St, Tain, IV19 1BJ, United Kingdom.</p>
    </div>
  </footer>
</body>
</html>
