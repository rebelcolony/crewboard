<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "CrewBoard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme">
    <nav class="navbar">
      <div class="navbar-brand">
        <%= link_to "CrewBoard", root_path, class: "navbar-logo" %>
      </div>

      <div class="navbar-links">
        <%= link_to "Dashboard", root_path, class: "navbar-link #{'active' if controller_name == 'dashboard'}" %>
        <%= link_to "Projects", projects_path, class: "navbar-link #{'active' if controller_name == 'projects'}" %>
        <%= link_to "Crew", crew_members_path, class: "navbar-link #{'active' if controller_name == 'crew_members'}" %>
      </div>

      <div class="navbar-actions">
        <% if authenticated? %>
          <%= link_to "Billing", billing_path, class: "navbar-link" %>
          <% if Current.manager&.super_admin? %>
            <%= link_to "Admin", admin_root_path, class: "navbar-link" %>
          <% end %>
        <% end %>

        <button class="theme-toggle" data-action="click->theme#toggle" data-theme-target="button" title="Toggle theme">
          <span class="theme-toggle-icon" data-theme-target="icon"></span>
        </button>

        <% if authenticated? %>
          <%= button_to "Sign Out", session_path, method: :delete, class: "btn btn-sm btn-secondary" %>
        <% end %>
      </div>
    </nav>

    <main class="main-content">
      <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="alert alert-danger"><%= flash[:alert] %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
