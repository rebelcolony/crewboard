<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "CrewControl" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/icon-128.png" type="image/png" sizes="128x128">
    <link rel="icon" href="/icon-256.png" type="image/png" sizes="256x256">
    <link rel="apple-touch-icon" href="/icon.png" sizes="512x512">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme">
    <nav class="navbar" data-controller="mobile-nav" data-action="resize@window->mobile-nav#closeOnDesktop">
      <div class="navbar-brand">
        <%= link_to dashboard_path, class: "navbar-logo" do %>
          CrewControl<% if Current.account %><span class="navbar-tenant"> / <%= Current.account.name %></span><% end %>
        <% end %>
      </div>

      <button
        type="button"
        class="nav-menu-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        data-action="click->mobile-nav#toggle"
        data-mobile-nav-target="button">
        <span aria-hidden="true">&#9776;</span>
      </button>

      <div class="nav-menu-panel" data-mobile-nav-target="menu">
        <div class="navbar-links">
          <%= link_to dashboard_path, class: "navbar-link #{'active' if controller_name == 'dashboard'}", data: { action: "click->mobile-nav#close" } do %>
            <i class="fa-solid fa-grip"></i> Dashboard
          <% end %>
          <%= link_to projects_path, class: "navbar-link #{'active' if controller_name == 'projects'}", data: { action: "click->mobile-nav#close" } do %>
            <i class="fa-solid fa-folder-open"></i> Projects
          <% end %>
          <%= link_to crew_members_path, class: "navbar-link #{'active' if controller_name == 'crew_members'}", data: { action: "click->mobile-nav#close" } do %>
            <i class="fa-solid fa-users"></i> Crew
          <% end %>
          <% if authenticated? %>
            <%= link_to invites_path, class: "navbar-link #{'active' if controller_name == 'invites'}", data: { action: "click->mobile-nav#close" } do %>
              <i class="fa-solid fa-user-plus"></i> Team
            <% end %>
            <%= link_to billing_path, class: "navbar-link #{'active' if controller_name == 'billings'}", data: { action: "click->mobile-nav#close" } do %>
              <i class="fa-solid fa-credit-card"></i> Billing
            <% end %>
            <%= link_to profile_path, class: "navbar-link #{'active' if controller_name == 'profile'}", data: { action: "click->mobile-nav#close" } do %>
              <i class="fa-solid fa-user-gear"></i> Profile
            <% end %>
            <% if Current.manager&.super_admin? %>
              <%= link_to admin_root_path, class: "navbar-link", data: { action: "click->mobile-nav#close" } do %>
                <i class="fa-solid fa-shield-halved"></i> Admin
              <% end %>
            <% end %>
          <% end %>
        </div>

        <div class="navbar-actions">
          <button class="theme-toggle" data-action="click->theme#toggle" data-theme-target="button" title="Toggle theme">
            <span class="theme-toggle-icon" data-theme-target="icon"></span>
          </button>

          <% if authenticated? %>
            <%= button_to "Sign Out", session_path, method: :delete, class: "btn btn-sm btn-secondary" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="main-content">
      <% if flash[:notice] %>
        <div class="alert alert-success"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="alert alert-danger"><%= flash[:alert] %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
