<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Admin — CrewControl" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme">
    <nav class="navbar" data-controller="mobile-nav" data-action="resize@window->mobile-nav#closeOnDesktop turbo:before-cache@document->mobile-nav#closeBeforeCache">
      <div class="navbar-brand">
        <%= link_to "CrewControl", root_path, class: "navbar-logo" %>
        <span class="admin-badge">Admin</span>
      </div>

      <button
        type="button"
        class="nav-menu-toggle"
        aria-label="Toggle navigation"
        aria-controls="admin-navigation"
        aria-expanded="false"
        data-action="click->mobile-nav#toggle"
        data-mobile-nav-target="button">
        <span class="nav-menu-toggle-icon" aria-hidden="true"></span>
      </button>

      <div id="admin-navigation" class="nav-menu-panel" data-mobile-nav-target="menu" hidden aria-hidden="true">
        <button
          type="button"
          class="nav-menu-overlay"
          aria-label="Close navigation"
          tabindex="-1"
          data-action="click->mobile-nav#closeFromOverlay"
          data-mobile-nav-target="overlay"></button>

        <div class="nav-menu-drawer" data-mobile-nav-target="panel" role="dialog" aria-modal="true" aria-label="Admin navigation">
          <div class="nav-menu-header">
            <p class="nav-menu-title">Admin</p>
            <button
              type="button"
              class="nav-menu-close"
              aria-label="Close navigation"
              data-action="click->mobile-nav#close"
              data-mobile-nav-target="closeButton focusable">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>

          <div class="navbar-links admin-mobile-links">
            <%= link_to "Dashboard", admin_root_path, class: "navbar-link #{'active' if controller_name == 'dashboard'}", data: { action: "click->mobile-nav#close", mobile_nav_target: "focusable" } %>
            <%= link_to "Accounts", admin_accounts_path, class: "navbar-link #{'active' if controller_name == 'accounts'}", data: { action: "click->mobile-nav#close", mobile_nav_target: "focusable" } %>
            <%= link_to "Subscriptions", admin_subscriptions_path, class: "navbar-link #{'active' if controller_name == 'subscriptions'}", data: { action: "click->mobile-nav#close", mobile_nav_target: "focusable" } %>
          </div>

          <div class="navbar-links">
            <%= link_to "Back to App", root_path, class: "navbar-link", data: { action: "click->mobile-nav#close", mobile_nav_target: "focusable" } %>
          </div>

          <div class="navbar-actions">
            <button class="theme-toggle" data-action="click->theme#toggle" data-theme-target="button" data-mobile-nav-target="focusable" title="Toggle theme">
              <span class="theme-toggle-icon" data-theme-target="icon"></span>
            </button>

            <%= button_to "Sign Out", session_path, method: :delete, class: "btn btn-sm btn-secondary", data: { action: "click->mobile-nav#close", mobile_nav_target: "focusable" } %>
          </div>
        </div>
      </div>
    </nav>

    <div class="admin-layout">
      <aside class="admin-sidebar">
        <%= link_to admin_root_path, class: "admin-sidebar-link #{'active' if controller_name == 'dashboard'}" do %>
          <i class="fa-solid fa-chart-line"></i> Dashboard
        <% end %>
        <%= link_to admin_accounts_path, class: "admin-sidebar-link #{'active' if controller_name == 'accounts'}" do %>
          <i class="fa-solid fa-building"></i> Accounts
        <% end %>
        <%= link_to admin_subscriptions_path, class: "admin-sidebar-link #{'active' if controller_name == 'subscriptions'}" do %>
          <i class="fa-solid fa-receipt"></i> Subscriptions
        <% end %>
      </aside>

      <main class="admin-main">
        <% if flash[:notice] %>
          <div class="alert alert-success"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert] %>
          <div class="alert alert-danger"><%= flash[:alert] %></div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
