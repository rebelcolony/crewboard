<div class="page-header">
  <h1>Billing</h1>
</div>

<div class="billing-grid">
  <%# Current Plan %>
  <div class="card">
    <h3 style="margin-bottom: 1rem;">Current Plan</h3>
    <div class="detail-row">
      <span class="detail-label">Plan</span>
      <span>
        <span class="badge badge-<%= @subscription ? 'success' : 'secondary' %>">
          <%= @account.plan_name.capitalize %>
        </span>
      </span>
    </div>
    <% if @subscription %>
      <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="badge badge-<%= @subscription.active? ? 'success' : 'warning' %>"><%= @subscription.status.capitalize %></span>
      </div>
      <% if @subscription.current_period_end %>
        <div class="detail-row">
          <span class="detail-label">Current Period</span>
          <span><%= @subscription.current_period_start&.strftime("%b %d, %Y") %> – <%= @subscription.current_period_end.strftime("%b %d, %Y") %></span>
        </div>
      <% end %>
      <% if @subscription.trial_ends_at %>
        <div class="detail-row">
          <span class="detail-label">Trial Ends</span>
          <span><%= @subscription.trial_ends_at.strftime("%b %d, %Y") %></span>
        </div>
      <% end %>
      <% if @subscription.ends_at %>
        <div class="detail-row">
          <span class="detail-label">Cancels On</span>
          <span><%= @subscription.ends_at.strftime("%b %d, %Y") %></span>
        </div>
      <% end %>
      <div style="margin-top: 1rem;">
        <%= button_to "Manage Billing", portal_billing_path, method: :post, class: "btn btn-secondary" %>
      </div>
    <% else %>
      <div style="margin-top: 1rem;">
        <p class="text-secondary">You're on the free plan (up to <%= @account.project_limit %> projects).</p>
        <%= link_to "Upgrade", pricing_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>

  <%# Payment Method %>
  <div class="card">
    <h3 style="margin-bottom: 1rem;">Payment Method</h3>
    <% if @payment_methods.any? %>
      <% @payment_methods.each do |pm| %>
        <div class="detail-row">
          <span class="detail-label">Card</span>
          <span>
            <i class="fa-solid fa-credit-card"></i>
            ···· <%= pm.data&.dig("last4") || "****" %>
            <% if pm.data&.dig("exp_month") && pm.data&.dig("exp_year") %>
              (<%= pm.data["exp_month"] %>/<%= pm.data["exp_year"] %>)
            <% end %>
            <% if pm.default? %>
              <span class="badge badge-accent">Default</span>
            <% end %>
          </span>
        </div>
      <% end %>
    <% else %>
      <p class="text-secondary">No payment method on file.</p>
    <% end %>
  </div>
</div>

<%# Invoices / Charges %>
<div class="card" style="margin-top: 1.5rem;">
  <h3 style="margin-bottom: 1rem;">Payment History</h3>
  <% if @charges.any? %>
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Amount</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @charges.each do |charge| %>
          <tr>
            <td data-label="Date"><%= charge.created_at.strftime("%b %d, %Y") %></td>
            <td data-label="Amount"><%= number_to_currency(charge.amount / 100.0, unit: charge.currency == "gbp" ? "£" : "$") %></td>
            <td data-label="Status">
              <span class="badge badge-<%= charge.amount_refunded.to_i > 0 ? 'warning' : 'success' %>">
                <%= charge.amount_refunded.to_i > 0 ? "Refunded" : "Paid" %>
              </span>
            </td>
            <td data-label="Receipt" class="table-actions">
              <% if charge.data&.dig("receipt_url").present? %>
                <%= link_to "Receipt", charge.data["receipt_url"], target: "_blank", rel: "noopener", class: "btn btn-sm btn-secondary" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-secondary" style="text-align: center; padding: 2rem;">No payments yet.</p>
  <% end %>
</div>
