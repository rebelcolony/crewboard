# Secrets for Kamal deployments.
# DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Master key — used for both staging and production unless overridden
RAILS_MASTER_KEY=$(cat config/master.key)

# Database password — set via environment variable or password manager
# For staging: export DATABASE_PASSWORD=your_staging_db_password
# For production: export DATABASE_PASSWORD=your_production_db_password
DATABASE_PASSWORD=${DATABASE_PASSWORD:-}

# Registry password (uncomment if using an authenticated registry)
# KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
