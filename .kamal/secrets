# Secrets for Kamal deployment.
# DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Master key for Rails credentials
RAILS_MASTER_KEY=$(cat config/master.key)

# Database password — set via environment variable before deploying:
#   export DATABASE_PASSWORD=your_secure_password
DATABASE_PASSWORD=${DATABASE_PASSWORD:-}

# Same password used for the PostgreSQL accessory container
POSTGRES_PASSWORD=${DATABASE_PASSWORD:-}

# Docker Hub password — set via environment variable before deploying:
#   export KAMAL_REGISTRY_PASSWORD=your_dockerhub_token
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD:-}
