# Secrets for Kamal deployment — fetched from 1Password.
#
# Prerequisites:
#   1. 1Password desktop app with CLI integration enabled
#   2. "CrewBoard Production" item in the "Shared" vault with fields:
#      RAILS_MASTER_KEY, DATABASE_PASSWORD, KAMAL_REGISTRY_PASSWORD

SECRETS=$(kamal secrets fetch --adapter 1password --account rebelcolony.1password.com --from "Shared/CrewBoard Production" RAILS_MASTER_KEY DATABASE_PASSWORD KAMAL_REGISTRY_PASSWORD)

RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY $SECRETS)
DATABASE_PASSWORD=$(kamal secrets extract DATABASE_PASSWORD $SECRETS)
POSTGRES_PASSWORD=$(kamal secrets extract DATABASE_PASSWORD $SECRETS)
KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD $SECRETS)
